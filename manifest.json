{
  "manifest_version": 3,
  "name": "AI Chat Reader",
  "version": "0.1.0",
  "description": "快速查看 AI 会话并跳转定位，支持导出对话为 Markdown",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat2-api.qianwen.com/*",
    "https://dashscope.aliyuncs.com/*",
    "https://api.openai.com/*",
    "https://*.openrouter.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/content/injected/*", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
